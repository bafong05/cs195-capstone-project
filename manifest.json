{
  "manifest_version": 3,
  "name": "Screen Time Momentum",
  "version": "1.0",
  "description": "Tracks browsing visits and groups them into sessions.",
  "permissions": [
    "tabs",
    "storage",
    "webNavigation",
    "notifications",
    "alarms",
    "idle"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["activity.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
